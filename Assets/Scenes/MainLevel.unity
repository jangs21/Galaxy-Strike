  m_Script: {fileID: 11500000, guid: c8ca7b0f8ba50e14a95fc540fa073638, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueLines
  dialogueText: {fileID: 333381338}
  timelineTextLines:
  - 'Nehpets: We''re glad to have you here Lieutenant.  We could really use your
    help!'
  - 'Nehpets: Like shooting fish in a barrel! '
  - 'Nehpets: It''s a trap!  Get out of there. '
  - 'Kcir: Crikey!  Looks like you could use a hand. '
  - 'Nehpets: Never thought I''d see your face around here general...'
  - 'Kcir: Righteo let''s finish this once and for all.'
  - 'Kcir: Struth!  Looks like the galaxy just got a little more safe. '
  - 'Nehpets: Yeeeehaw!!  You did it!'
